{
  "name": "motiva",
  "version": "0.1.0",
  "description": "AI agent orchestrator that gives existing agents motivation — goal-driven task selection, progress observation, and completion judgment",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "motiva": "dist/cli-runner.js"
  },
  "keywords": ["ai", "agent", "orchestrator", "motivation", "autonomous", "llm"],
  "repository": {
    "type": "git",
    "url": "https://github.com/yuyoshimuta/motiva.git"
  },
  "files": ["dist", "README.md", "LICENSE"],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "tui": "node dist/tui/entry.js"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "ink": "^5.2.1",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "react": "^18.3.1",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "^18.3.28",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0"
  }
}
