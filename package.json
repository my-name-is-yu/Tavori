{
  "name": "conatus",
  "version": "0.1.0",
  "description": "AI agent orchestrator that gives existing agents the drive to persist — set a goal, and Conatus observes, delegates, verifies, and loops until done.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "license": "MIT",
  "author": "yuyoshimuta",
  "homepage": "https://github.com/my-name-is-yu/Conatus#readme",
  "bugs": {
    "url": "https://github.com/my-name-is-yu/Conatus/issues"
  },
  "bin": {
    "conatus": "dist/cli-runner.js"
  },
  "keywords": [
    "ai",
    "agent",
    "orchestrator",
    "motivation",
    "autonomous",
    "goal-driven",
    "task-discovery",
    "satisficing",
    "llm",
    "ai-agent",
    "multi-agent",
    "typescript"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/my-name-is-yu/Conatus.git"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run --exclude tests/e2e",
    "test:all": "vitest run",
    "test:e2e": "vitest run tests/e2e",
    "test:changed": "vitest run --changed",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "tui": "node dist/tui/entry.js"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "ink": "^5.2.1",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "js-yaml": "^4.1.1",
    "nodemailer": "^8.0.2",
    "openai": "^6.27.0",
    "react": "^18.3.1",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.0.0",
    "@types/nodemailer": "^7.0.11",
    "@types/react": "^18.3.28",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0"
  }
}
